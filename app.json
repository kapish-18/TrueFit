{
  "expo": {
    "name": "TrueFit",
    "slug": "truefit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "truefit",
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0F1A",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.truefit.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "27c72b2d-4012-42ea-a5bd-db9874d3631c"
      }
    }
  }
}
